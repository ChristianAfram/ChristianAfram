{
  "name": "prompt-regression-harness",
  "version": "0.1.0",
  "description": "A CLI regression harness for LLM prompts — pytest for your prompts.",
  "type": "module",
  "bin": {
    "promptreg": "./bin/promptreg.js"
  },
  "scripts": {
    "test": "node bin/promptreg.js run",
    "run:example": "node bin/promptreg.js run --cases cases/ --prompts prompts/"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.9",
    "ajv": "^8.17.1",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.3",
    "commander": "^12.1.0",
    "diff": "^5.2.0",
    "glob": "^11.0.0",
    "js-yaml": "^4.1.0",
    "ora": "^8.0.1",
    "tiktoken": "^1.0.15"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["prompt", "regression", "testing", "llm", "claude", "eval"],
  "license": "MIT"
}
